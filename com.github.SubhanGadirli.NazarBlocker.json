{
  "app-id": "com.github.SubhanGadirli.NazarBlocker",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "nazar",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.DBus.Properties",
    "--talk-name=org.ayatana.indicator.application"
  ],
  "modules": [
    {
      "name": "nazar-blocker",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
