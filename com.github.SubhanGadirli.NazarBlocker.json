{
  "app-id": "com.github.SubhanGadirli.NazarBlocker",
  "version": "1.0",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "nazar",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "libayatana-appindicator",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/AyatanaIndicators/libayatana-appindicator.git",
          "branch": "master"
        }
      ]
    },
    {
      "name": "nazar-blocker",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
